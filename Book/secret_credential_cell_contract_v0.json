{
  "version": 0,
  "status": "draft",
  "lastUpdated": "2026-06-17",
  "cell": {
    "name": "SecretCredentialCell",
    "endpoint": "cell:///entity/credentials",
    "agentDRoute": "credentials",
    "flowTopic": "entity.credentials",
    "responsibility": "Entity-scoped credential storage, policy, authorization and bounded provider invocation without exposing raw secrets to scaffolds."
  },
  "security": {
    "rawSecretGetAllowed": false,
    "preferredStorage": "keychain-wrapped-chachapoly-vault",
    "acceptableAppleMVP": "raw secret in Keychain, metadata only in Cell state",
    "preferredAppleMVP": "ChaChaPoly encrypted credential envelope in private vault, wrapping/data key in Keychain",
    "secretRefExample": "secret://entity/provider/featherless/api-key",
    "mustNeverStoreRawSecretsIn": [
      "Book",
      "Deliverables",
      "Prompts",
      "CellConfiguration",
      "Skeleton",
      "ordinary Cell state",
      "logs",
      "benchmark results",
      "Git"
    ]
  },
  "get": [
    {
      "keypath": "credentials.state",
      "returns": "Cell health, storage backend, policy version, counts and current route status.",
      "secretExposure": "none"
    },
    {
      "keypath": "credentials.list",
      "returns": "Credential summaries visible to requester under current Agreement/capability.",
      "secretExposure": "none"
    },
    {
      "keypath": "credentials.describe",
      "returns": "Metadata for one credential.",
      "secretExposure": "none"
    },
    {
      "keypath": "credentials.policy",
      "returns": "Allowed providers, purposes, data classes, scaffold ids and spend caps.",
      "secretExposure": "none"
    },
    {
      "keypath": "credentials.audit",
      "returns": "Bounded audit digest page with hashes/previews only.",
      "secretExposure": "no raw secret, no full sensitive prompt"
    },
    {
      "keypath": "providers.allowed",
      "returns": "Provider/model routes available to requester after policy filtering.",
      "secretExposure": "none"
    }
  ],
  "set": [
    {
      "keypath": "credential.register",
      "expects": "CredentialRegisterRequest",
      "returns": "CredentialRegisterResult",
      "secretHandling": "Accepts secret only as write input; never echoes secret."
    },
    {
      "keypath": "credential.rotate",
      "expects": "CredentialRotateRequest",
      "returns": "CredentialRotateResult",
      "secretHandling": "Accepts replacement secret only as write input; old key version retired."
    },
    {
      "keypath": "credential.revoke",
      "expects": "CredentialRevokeRequest",
      "returns": "CredentialRevokeResult",
      "secretHandling": "No raw secret."
    },
    {
      "keypath": "credential.delete",
      "expects": "CredentialDeleteRequest",
      "returns": "CredentialDeleteResult",
      "secretHandling": "Deletes encrypted secret when retention policy permits."
    },
    {
      "keypath": "credential.test",
      "expects": "CredentialTestRequest",
      "returns": "CredentialTestResult",
      "secretHandling": "Uses secret inside trusted boundary only."
    },
    {
      "keypath": "credential.authorizeUse",
      "expects": "CredentialAuthorizeUseRequest",
      "returns": "CredentialAuthorizeUseResult",
      "secretHandling": "Returns short-lived local authorization, never raw secret."
    },
    {
      "keypath": "provider.invoke",
      "expects": "ProviderInvokeRequest",
      "returns": "ProviderInvokeResult",
      "secretHandling": "Optional trusted proxy invocation; secret remains inside cell/AgentD boundary."
    }
  ],
  "schemas": {
    "CredentialRegisterRequest": {
      "required": [
        "providerID",
        "credentialLabel",
        "secret",
        "secretKind",
        "ownerIdentityDomain",
        "allowedPurposeRefs",
        "allowedDataClasses"
      ],
      "properties": {
        "providerID": "String",
        "credentialLabel": "String",
        "secret": "String write-only",
        "secretKind": "api_key | oauth_refresh_token | provider_session_token | other",
        "ownerIdentityDomain": "String",
        "allowedPurposeRefs": "String[]",
        "allowedScaffolds": "String[]",
        "allowedDataClasses": "String[]",
        "blockedDataClasses": "String[]",
        "maxMonthlySpendNOK": "Number?",
        "requiresUserApproval": "Bool",
        "rotationDays": "Int?",
        "dpaStatus": "unknown | not_required | pending | approved | rejected"
      }
    },
    "CredentialSummary": {
      "properties": {
        "credentialID": "String",
        "providerID": "String",
        "credentialLabel": "String",
        "secretRef": "String",
        "storageBackend": "String",
        "ownerIdentityDomain": "String",
        "allowedPurposeRefs": "String[]",
        "allowedScaffolds": "String[]",
        "allowedDataClasses": "String[]",
        "blockedDataClasses": "String[]",
        "status": "active | revoked | expired | pending_rotation",
        "createdAt": "ISO-8601",
        "rotatesAt": "ISO-8601?",
        "lastUsedAt": "ISO-8601?",
        "dpaStatus": "String"
      }
    },
    "CredentialAuthorizeUseRequest": {
      "required": [
        "credentialID",
        "providerID",
        "modelID",
        "purposeRef",
        "scaffoldID",
        "dataClass"
      ],
      "properties": {
        "credentialID": "String",
        "providerID": "String",
        "modelID": "String",
        "purposeRef": "String",
        "scaffoldID": "String",
        "dataClass": "String",
        "estimatedInputTokens": "Int?",
        "estimatedOutputTokens": "Int?",
        "requiresNetwork": "Bool",
        "correlationID": "String?"
      }
    },
    "CredentialAuthorizeUseResult": {
      "properties": {
        "status": "authorized | denied",
        "authorizationID": "String?",
        "credentialID": "String",
        "providerID": "String",
        "modelID": "String?",
        "expiresAt": "ISO-8601?",
        "maxUses": "Int?",
        "mustInvokeInsideBoundary": "Bool",
        "reason": "String?",
        "requiredAction": "String?"
      }
    },
    "ProviderInvokeRequest": {
      "required": [
        "providerID",
        "modelID",
        "credentialID",
        "purposeRef",
        "scaffoldID",
        "dataClass",
        "promptManifest",
        "request"
      ],
      "properties": {
        "providerID": "String",
        "modelID": "String",
        "credentialID": "String",
        "purposeRef": "String",
        "scaffoldID": "String",
        "dataClass": "String",
        "promptManifest": "PromptManifest",
        "request": "Provider-specific request object",
        "correlationID": "String?"
      }
    },
    "PromptManifest": {
      "required": [
        "promptHash",
        "containsPII",
        "sources"
      ],
      "properties": {
        "promptHash": "sha256:<hex>",
        "containsPII": "Bool",
        "sources": "String[]",
        "redactionPolicy": "String",
        "retentionClass": "none | hash_only | bounded_debug | full_debug_for_synthetic_only"
      }
    }
  },
  "denialReasons": [
    "missingAgreement",
    "missingCapability",
    "wrongIdentityDomain",
    "purposeNotAllowed",
    "scaffoldNotAllowed",
    "dataClassBlocked",
    "dpaStatusInsufficient",
    "spendCapExceeded",
    "credentialRevoked",
    "credentialExpired",
    "modelLicenseBlocked",
    "promptManifestMissing",
    "userApprovalRequired",
    "vaultEnvelopeInvalid"
  ],
  "flowEvents": [
    "credential.registered",
    "credential.rotated",
    "credential.revoked",
    "credential.deleted",
    "credential.tested",
    "credential.use.authorized",
    "credential.use.denied",
    "provider.invocation.completed",
    "provider.invocation.failed"
  ],
  "testRequirements": [
    "Register credential returns metadata and never echoes secret.",
    "List/describe/audit never returns raw secret.",
    "Allowed purpose/data class returns authorized use.",
    "Blocked data class returns denied result.",
    "Revoked credential cannot be used.",
    "Rotation invalidates old key version.",
    "Provider invoke does not log prompt/response when data class blocks logging.",
    "Missing Agreement/capability is denied.",
    "Wrong identity domain is denied.",
    "Corrupt vault envelope fails closed."
  ]
}
