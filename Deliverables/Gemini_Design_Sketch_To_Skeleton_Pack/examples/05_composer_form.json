{
  "name": "Chat Composer",
  "uuid": "GEMINI-EXAMPLE-05",
  "skeleton": {
    "ScrollView": {
      "axis": "vertical",
      "elements": [
        {
          "Section": {
            "header": {
              "Text": {
                "text": "Compose message",
                "modifiers": {
                  "fontStyle": "title3",
                  "fontWeight": "semibold"
                }
              }
            },
            "content": [
              {
                "TextField": {
                  "placeholder": "Subject",
                  "sourceKeypath": "chat.subject",
                  "targetKeypath": "chat.subject.set",
                  "modifiers": {
                    "padding": 10,
                    "borderWidth": 1,
                    "borderColor": "#D1D5DB",
                    "cornerRadius": 10
                  }
                }
              },
              {
                "TextArea": {
                  "placeholder": "Write message",
                  "sourceKeypath": "chat.editorDraft",
                  "targetKeypath": "chat.editorDraft.set",
                  "minLines": 5,
                  "maxLines": 10,
                  "submitOnEnter": false,
                  "modifiers": {
                    "padding": 10,
                    "borderWidth": 1,
                    "borderColor": "#D1D5DB",
                    "cornerRadius": 12
                  }
                }
              },
              {
                "Toggle": {
                  "label": "Render preview as markdown",
                  "keypath": "chat.renderMarkdown",
                  "isOn": true
                }
              },
              {
                "Text": {
                  "url": "cell:///Porthole/chat.previewMarkdown",
                  "modifiers": {
                    "styleRole": "markdown",
                    "padding": 8,
                    "background": "#F8FAFC",
                    "cornerRadius": 12
                  }
                }
              },
              {
                "Button": {
                  "keypath": "chat.submitDraft",
                  "label": "Send message",
                  "modifiers": {
                    "padding": 10,
                    "borderWidth": 1,
                    "borderColor": "#0F172A",
                    "cornerRadius": 12
                  }
                }
              }
            ]
          }
        }
      ]
    }
  }
}
